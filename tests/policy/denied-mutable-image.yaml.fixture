apiVersion: v1
kind: Pod
metadata:
  name: denied-mutable-image
  namespace: shirokuma-dev
spec:
  containers:
    - name: app
      image: registry.example.com/shirokuma/app:latest
      resources:
        requests:
          cpu: 100m
          memory: 64Mi
        limits:
          cpu: 500m
          memory: 128Mi
