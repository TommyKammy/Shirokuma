apiVersion: v1
kind: Pod
metadata:
  name: allowed-pod
  namespace: shirokuma-dev
spec:
  containers:
    - name: app
      image: registry.example.com/shirokuma/app@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      securityContext:
        privileged: false
      resources:
        requests:
          cpu: 100m
          memory: 64Mi
        limits:
          cpu: 500m
          memory: 128Mi
---
apiVersion: v1
kind: Service
metadata:
  name: allowed-internal-service
  namespace: shirokuma-dev
spec:
  type: ClusterIP
  selector:
    app: allowed
  ports:
    - port: 8080
      targetPort: 8080
