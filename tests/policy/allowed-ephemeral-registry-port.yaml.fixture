apiVersion: v1
kind: Pod
metadata:
  name: allowed-ephemeral-registry-port
  namespace: shirokuma-dev
spec:
  containers:
    - name: app
      image: registry.example.com:5000/shirokuma/app@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      resources:
        requests:
          cpu: 100m
          memory: 64Mi
        limits:
          cpu: 500m
          memory: 128Mi
  ephemeralContainers:
    - name: debugger
      image: registry.example.com:5000/shirokuma/debugger@sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
      securityContext:
        privileged: false
