apiVersion: v1
kind: Pod
metadata:
  name: denied-ephemeral-container
  namespace: shirokuma-dev
spec:
  containers:
    - name: app
      image: registry.example.com/shirokuma/app@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      resources:
        requests:
          cpu: 100m
          memory: 64Mi
        limits:
          cpu: 500m
          memory: 128Mi
  ephemeralContainers:
    - name: debugger
      image: registry.example.com/shirokuma/debugger:latest
      securityContext:
        privileged: true
