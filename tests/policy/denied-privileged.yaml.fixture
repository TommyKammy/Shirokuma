apiVersion: v1
kind: Pod
metadata:
  name: denied-privileged
  namespace: shirokuma-dev
spec:
  containers:
    - name: app
      image: registry.example.com/shirokuma/app@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      securityContext:
        privileged: true
      resources:
        requests:
          cpu: 100m
          memory: 64Mi
        limits:
          cpu: 500m
          memory: 128Mi
