apiVersion: v1
kind: Pod
metadata:
  name: denied-host-namespace
  namespace: shirokuma-dev
spec:
  hostNetwork: true
  containers:
    - name: app
      image: registry.example.com/shirokuma/app@sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
      resources:
        requests:
          cpu: 100m
          memory: 64Mi
        limits:
          cpu: 500m
          memory: 128Mi
