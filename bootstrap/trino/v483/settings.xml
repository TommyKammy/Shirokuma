<?xml version="1.0" encoding="UTF-8"?>
<settings xmlns="http://maven.apache.org/SETTINGS/1.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.2.0 https://maven.apache.org/xsd/settings-1.2.0.xsd">
  <interactiveMode>false</interactiveMode>
  <offline>false</offline>
  <mirrors>
    <mirror>
      <id>shirokuma-central</id>
      <mirrorOf>central</mirrorOf>
      <name>Pin the Central repository id to Maven Central</name>
      <url>https://repo.maven.apache.org/maven2/</url>
    </mirror>
    <mirror>
      <id>shirokuma-confluent</id>
      <mirrorOf>confluent</mirrorOf>
      <name>Pin the Confluent repository id to Confluent packages</name>
      <url>https://packages.confluent.io/maven/</url>
    </mirror>
    <mirror>
      <id>shirokuma-central-fallback</id>
      <mirrorOf>*</mirrorOf>
      <name>Route every other repository id through Maven Central</name>
      <url>https://repo.maven.apache.org/maven2/</url>
    </mirror>
  </mirrors>
  <profiles>
    <profile>
      <id>shirokuma-trino-483</id>
      <repositories>
        <repository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2/</url>
          <releases>
            <enabled>true</enabled>
            <checksumPolicy>fail</checksumPolicy>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
        <repository>
          <id>confluent</id>
          <url>https://packages.confluent.io/maven/</url>
          <releases>
            <enabled>true</enabled>
            <checksumPolicy>fail</checksumPolicy>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </repository>
      </repositories>
      <pluginRepositories>
        <pluginRepository>
          <id>central</id>
          <url>https://repo.maven.apache.org/maven2/</url>
          <releases>
            <enabled>true</enabled>
            <checksumPolicy>fail</checksumPolicy>
          </releases>
          <snapshots>
            <enabled>false</enabled>
          </snapshots>
        </pluginRepository>
      </pluginRepositories>
    </profile>
  </profiles>
  <activeProfiles>
    <activeProfile>shirokuma-trino-483</activeProfile>
  </activeProfiles>
</settings>
